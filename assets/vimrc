" ============================================================================
" .vimrc — 代码浏览配置 (Python / TypeScript)
"   结构 / 跳转 / 全局搜索 / 调用关系 / git blame
" ============================================================================

set nocompatible
filetype plugin indent on
syntax on

" ---------- 基础体验 ----------
set number                         " 绝对行号(固定不变)
set hidden                         " 允许在未保存的 buffer 间切换
set updatetime=300                 " 更快的 CursorHold(coc 行内 blame/诊断)
set signcolumn=yes                 " 始终显示 sign 列,避免抖动
set mouse=a
set ignorecase smartcase
set incsearch hlsearch
set scrolloff=5
set splitright splitbelow
set tabstop=4 shiftwidth=4 expandtab
set encoding=utf-8
set termguicolors
let mapleader = " "                " <Space> 作为 leader 键

" ---------- 插件 ----------
call plug#begin('~/.vim/plugged')
  " 全局搜索 (依赖系统 fzf + ripgrep)
  Plug '~/.fzf'
  Plug 'junegunn/fzf.vim'

  " LSP: 跳转 / 引用 / 大纲 / 调用关系 / 诊断
  Plug 'neoclide/coc.nvim', {'branch': 'release'}

  " Git: blame / 历史 / diff
  Plug 'tpope/vim-fugitive'

  " 文件树 (可选,浏览目录)
  Plug 'preservim/nerdtree'

  " 配色与状态栏
  Plug 'vim-airline/vim-airline'
  Plug 'morhetz/gruvbox'
call plug#end()

" ---------- 配色 ----------
set background=dark
silent! colorscheme gruvbox

" ============================================================================
" 全局搜索 (fzf.vim)
"   排除 vendored 目录,否则会被海量文件淹没
" ============================================================================
" :Files / :Rg 都用 ripgrep 并跳过 cooked 等目录
let $FZF_DEFAULT_COMMAND = 'rg --files --hidden --follow ' .
      \ '--glob "!.git/*" --glob "!cooked/*" --glob "!**/node_modules/*" ' .
      \ '--glob "!**/dist/*" --glob "!**/*.so" --glob "!**/*.gz"'

" :Rg 全文搜索(同样排除 cooked / node_modules)
command! -bang -nargs=* Rg
      \ call fzf#vim#grep(
      \   'rg --column --line-number --no-heading --color=always --smart-case ' .
      \   '--glob "!cooked/*" --glob "!**/node_modules/*" --glob "!**/dist/*" -- ' .
      \   shellescape(<q-args>),
      \   1, fzf#vim#with_preview(), <bang>0)

" 文件/搜索快捷键
nnoremap <leader>f  :Files<CR>          " 按文件名找文件
nnoremap <leader>g  :Rg<CR>            " 全工程全文搜索
nnoremap <leader>b  :Buffers<CR>        " 切换已打开的 buffer
nnoremap <leader>l  :BLines<CR>        " 当前文件内搜索行
nnoremap <leader>/  :Rg <C-r><C-w><CR>  " 搜索光标下的单词

" ============================================================================
" coc.nvim — LSP (跳转 / 引用 / 大纲 / 调用关系)
" ============================================================================
" --- 跳转 ---
nmap <silent> gd <Plug>(coc-definition)        " 跳到定义
nmap <silent> gy <Plug>(coc-type-definition)   " 跳到类型定义
nmap <silent> gi <Plug>(coc-implementation)     " 跳到实现
nmap <silent> gr <Plug>(coc-references)         " 查看所有引用(被调用处)
" <C-o> 返回上一个位置,<C-i> 前进(vim 内置跳转列表)

" --- 代码结构 (outline) ---
nnoremap <silent> <leader>o  :CocOutline<CR>    " 当前文件符号大纲(类/函数)
nnoremap <silent> <leader>s  :CocList -I symbols<CR>  " 全工程符号搜索

" --- 调用关系 (call hierarchy) ---
nnoremap <silent> <leader>ci :call CocAction('showIncomingCalls')<CR>  " 谁调用了它
nnoremap <silent> <leader>co :call CocAction('showOutgoingCalls')<CR>  " 它调用了谁

" --- 悬浮文档 / 诊断 ---
nnoremap <silent> K :call CocActionAsync('doHover')<CR>  " 查看文档/签名
nmap <silent> [g <Plug>(coc-diagnostic-prev)
nmap <silent> ]g <Plug>(coc-diagnostic-next)

" --- 补全:回车确认,Tab 选择 ---
inoremap <silent><expr> <CR> coc#pum#visible() ? coc#pum#confirm() : "\<CR>"
inoremap <silent><expr> <Tab>
      \ coc#pum#visible() ? coc#pum#next(1) :
      \ CheckBackspace() ? "\<Tab>" : coc#refresh()
inoremap <expr><S-Tab> coc#pum#visible() ? coc#pum#prev(1) : "\<C-h>"
function! CheckBackspace() abort
  let col = col('.') - 1
  return !col || getline('.')[col - 1]  =~# '\s'
endfunction

" ============================================================================
" Git (vim-fugitive + coc-git)
" ============================================================================
nnoremap <leader>gb :Git blame<CR>     " 整个文件逐行 blame(提交人/时间/哈希)
nnoremap <leader>gl :Git log -- %<CR>  " 当前文件的提交历史
" 行内 blame(光标停留时显示该行提交人/时间)由 coc-git 提供,见下方 coc-settings

" ============================================================================
" 文件树 (NERDTree)
" ============================================================================
nnoremap <leader>e :NERDTreeToggle<CR>
nnoremap <leader>n :NERDTreeFind<CR>   " 在树中定位当前文件
let NERDTreeIgnore = ['\.pyc$', '\~$', '^cooked$', '^node_modules$', '^dist$']

" ============================================================================
" 快捷键速查表  ( <space>? 随时打开,q 关闭 )
" ============================================================================
function! s:OpenCheatsheet() abort
  let l:f = expand('~/.vim/cheatsheet.txt')
  if !filereadable(l:f)
    echohl WarningMsg | echo 'cheatsheet 未找到: ' . l:f | echohl None | return
  endif
  execute 'botright vsplit ' . fnameescape(l:f)
  setlocal buftype=nofile bufhidden=wipe nobuflisted noswapfile nomodifiable
  setlocal nonumber norelativenumber signcolumn=no
  vertical resize 80
  nnoremap <buffer><silent> q :close<CR>
endfunction
nnoremap <silent> <leader>? :call <SID>OpenCheatsheet()<CR>

" ============================================================================
" 大模型接入 (本机 claude CLI,无头模式 claude -p)
"   <space>ae  解释代码 (Visual 选区;普通模式则解释整个文件)
"   <space>ar  重构替换 (Visual 选中后输入指令,Claude 改写并替换选区)
"   说明:同步调用,Claude 返回前 vim 会短暂卡住,属正常。
" ============================================================================
function! s:RunClaude(prompt, text) abort
  " prompt 作为指令参数,text 作为标准输入喂给 claude
  let l:out = system('claude -p ' . shellescape(a:prompt), a:text)
  if v:shell_error != 0
    echohl ErrorMsg | echo 'claude 调用失败: ' . l:out | echohl None
    return ''
  endif
  return l:out
endfunction

" 去掉首尾的空行与 ```fenced``` 围栏,保证重构结果是纯代码
function! s:StripFences(lines) abort
  let l:l = copy(a:lines)
  while len(l:l) > 0 && l:l[0]  =~# '^\s*$' | call remove(l:l, 0)  | endwhile
  if    len(l:l) > 0 && l:l[0]  =~# '^\s*```' | call remove(l:l, 0)  | endif
  while len(l:l) > 0 && l:l[-1] =~# '^\s*$' | call remove(l:l, -1) | endwhile
  if    len(l:l) > 0 && l:l[-1] =~# '^\s*```' | call remove(l:l, -1) | endif
  return l:l
endfunction

function! s:OpenScratch(name, lines) abort
  botright new
  setlocal buftype=nofile bufhidden=wipe noswapfile nobuflisted filetype=markdown
  silent! execute 'file' fnameescape(a:name)
  call setline(1, a:lines)
  setlocal nomodifiable
  nnoremap <buffer><silent> q :close<CR>
  normal! gg
endfunction

" 上下文:Visual 调用取选区,Normal 调用取整个文件
function! s:Context(use_selection) abort
  if a:use_selection
    return join(getline(line("'<"), line("'>")), "\n")
  endif
  return join(getline(1, '$'), "\n")
endfunction

" 解释代码 (use_selection=1 用选区,=0 用整个文件)
function! AIExplain(use_selection) abort
  let l:code = s:Context(a:use_selection)
  echo 'Claude 正在解释...(请稍候)'
  let l:prompt = '你会通过标准输入收到一段 ' . &filetype .
        \ ' 代码。用中文简洁解释:它的作用、关键逻辑、以及可能的问题或副作用。'
  let l:out = s:RunClaude(l:prompt, l:code)
  if empty(l:out) | return | endif
  call s:OpenScratch('claude-explain', split(l:out, "\n"))
endfunction

" 重构替换:必须在 Visual 模式选中后调用
function! AIRefactor(...) abort
  let l:a = line("'<") | let l:b = line("'>")
  if l:a == 0 || l:b == 0
    echohl WarningMsg | echo '请先在 Visual 模式选中要重构的代码' | echohl None | return
  endif
  let l:instr = a:0 > 0 ? a:1 : input('重构指令: ')
  if empty(l:instr) | redraw | echo '已取消' | return | endif
  let l:code = join(getline(l:a, l:b), "\n")
  let l:prompt = '你会通过标准输入收到一段 ' . &filetype . ' 代码。按此要求改写:' .
        \ l:instr . ' 严格只输出改写后的代码本身,不要任何解释、不要 markdown 代码围栏。'
  echo 'Claude 正在重构...(请稍候)'
  let l:out = s:RunClaude(l:prompt, l:code)
  if empty(l:out) | return | endif
  let l:lines = s:StripFences(split(l:out, "\n"))
  if empty(l:lines) | echo 'Claude 返回为空,未改动' | return | endif
  silent execute l:a . ',' . l:b . 'delete _'
  call append(l:a - 1, l:lines)
  redraw | echo 'Claude 重构完成 (' . len(l:lines) . ' 行) — u 可撤销'
endfunction

" 自由提问:输入任意问题,把选区(Visual)或整个文件(Normal)作为上下文
function! AIAsk(use_selection, ...) abort
  let l:q = a:0 > 0 ? a:1 : input('问 Claude: ')
  if empty(l:q) | redraw | echo '已取消' | return | endif
  let l:ctx = s:Context(a:use_selection)
  echo 'Claude 思考中...(请稍候)'
  let l:prompt = '你会通过标准输入收到一段代码作为上下文(' . &filetype .
        \ ')。请用中文回答这个问题:' . l:q
  let l:out = s:RunClaude(l:prompt, l:ctx)
  if empty(l:out) | return | endif
  call s:OpenScratch('claude-ask', split(l:out, "\n"))
endfunction

xnoremap <silent> <leader>ae :<C-u>call AIExplain(1)<CR>
nnoremap <silent> <leader>ae :call AIExplain(0)<CR>
xnoremap <silent> <leader>aa :<C-u>call AIAsk(1)<CR>
nnoremap <silent> <leader>aa :call AIAsk(0)<CR>
xnoremap <silent> <leader>ar :<C-u>call AIRefactor()<CR>
